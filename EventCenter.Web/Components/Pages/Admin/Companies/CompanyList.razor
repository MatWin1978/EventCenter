@page "/admin/companies"
@attribute [Authorize(Roles = "Admin")]
@layout MainLayout
@rendermode InteractiveServer
@using EventCenter.Web.Domain.Entities
@using EventCenter.Web.Services
@inject CompanyService CompanyService

<PageTitle>Firmenstammdaten - Admin</PageTitle>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col">
            <h2>Firmenstammdaten</h2>
        </div>
        <div class="col text-end">
            <a href="/admin/companies/create" class="btn btn-primary">
                <span class="bi bi-plus-circle"></span> Neue Firma
            </a>
        </div>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center my-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Lade Firmen...</span>
            </div>
        </div>
    }
    else if (companies.Count == 0)
    {
        <div class="alert alert-info">
            Keine Firmen gefunden. <a href="/admin/companies/create">Erste Firma anlegen</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Firmenname</th>
                        <th>Ansprechpartner</th>
                        <th>E-Mail</th>
                        <th>Telefon</th>
                        <th>Ort</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var company in companies)
                    {
                        <tr>
                            <td>@company.Name</td>
                            <td>
                                @{
                                    var contact = string.Join(" ", new[] { company.ContactFirstName, company.ContactLastName }
                                        .Where(s => !string.IsNullOrEmpty(s)));
                                }
                                @(string.IsNullOrEmpty(contact) ? "-" : contact)
                            </td>
                            <td>@company.ContactEmail</td>
                            <td>@(company.ContactPhone ?? "-")</td>
                            <td>@(company.City ?? "-")</td>
                            <td>
                                <a href="/admin/companies/edit/@company.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Bearbeiten
                                </a>
                                <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => ConfirmDelete(company)">
                                    <i class="bi bi-trash"></i> Löschen
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (companyToDelete != null)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Firma löschen</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Soll die Firma <strong>@companyToDelete.Name</strong> wirklich gelöscht werden?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Abbrechen</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDelete" disabled="@deleting">
                        @if (deleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Löschen
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Company> companies = new();
    private bool isLoading = true;
    private string? errorMessage;
    private string? successMessage;
    private Company? companyToDelete;
    private bool deleting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCompanies();
    }

    private async Task LoadCompanies()
    {
        isLoading = true;
        companies = await CompanyService.GetAllAsync();
        isLoading = false;
    }

    private void ConfirmDelete(Company company)
    {
        companyToDelete = company;
        errorMessage = null;
    }

    private void CancelDelete()
    {
        companyToDelete = null;
    }

    private async Task ExecuteDelete()
    {
        if (companyToDelete == null) return;

        deleting = true;
        var (success, error) = await CompanyService.DeleteAsync(companyToDelete.Id);
        deleting = false;

        if (success)
        {
            successMessage = $"Firma \"{companyToDelete.Name}\" wurde gelöscht.";
            companyToDelete = null;
            await LoadCompanies();
        }
        else
        {
            errorMessage = error ?? "Fehler beim Löschen.";
            companyToDelete = null;
        }
    }
}
