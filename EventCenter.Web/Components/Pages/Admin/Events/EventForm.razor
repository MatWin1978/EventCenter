@page "/admin/events/create"
@page "/admin/events/edit/{EventId:int}"
@using EventCenter.Web.Domain.Entities
@using EventCenter.Web.Domain.Enums
@using EventCenter.Web.Services
@using EventCenter.Web.Infrastructure.Helpers
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Blazored.FluentValidation
@attribute [Authorize(Roles = "Admin")]
@layout MainLayout
@rendermode InteractiveServer
@inject EventService EventService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-10 offset-lg-1">
            <h2>@(isEditMode ? "Veranstaltung bearbeiten" : "Neue Veranstaltung anlegen")</h2>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @errorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success" role="alert">
                    @successMessage
                </div>
            }

            <EditForm Model="@Model" OnValidSubmit="@HandleValidSubmit">
                <FluentValidationValidator />
                <ValidationSummary />

                <!-- Section 1: Grunddaten (Basic Info) -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h4 class="mb-0">Grunddaten</h4>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Veranstaltungstyp *</label>
                            <InputSelect @bind-Value="Model.EventType" class="form-select" @bind-Value:after="OnEventTypeChanged">
                                <option value="@EventType.InPerson">Präsenzveranstaltung</option>
                                <option value="@EventType.Webinar">Webinar</option>
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label for="title" class="form-label">Titel *</label>
                            <InputText id="title" class="form-control" @bind-Value="Model.Title" />
                            <ValidationMessage For="@(() => Model.Title)" />
                        </div>

                        <div class="mb-3">
                            <label for="description" class="form-label">Beschreibung</label>
                            <InputTextArea id="description" class="form-control" rows="4" @bind-Value="Model.Description" />
                            <ValidationMessage For="@(() => Model.Description)" />
                        </div>

                        <div class="mb-3">
                            <label for="location" class="form-label">Ort *</label>
                            <InputText id="location" class="form-control" @bind-Value="Model.Location" />
                            <ValidationMessage For="@(() => Model.Location)" />
                        </div>

                        @if (Model.EventType == EventType.Webinar)
                        {
                            <div class="mb-3">
                                <label for="extUrl" class="form-label">Externe Anmelde-URL</label>
                                <InputText id="extUrl" class="form-control" @bind-Value="Model.ExternalRegistrationUrl"
                                           placeholder="https://..." />
                                <ValidationMessage For="@(() => Model.ExternalRegistrationUrl)" />
                                <div class="form-text text-muted">Erforderlich zum Veröffentlichen. Kann als Entwurf ohne URL gespeichert werden.</div>
                            </div>
                        }

                        @if (Model.EventType == EventType.InPerson)
                        {
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="maxCapacity" class="form-label">Maximale Kapazität</label>
                                    <InputNumber id="maxCapacity" class="form-control" @bind-Value="Model.MaxCapacity" />
                                    <ValidationMessage For="@(() => Model.MaxCapacity)" />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label for="maxCompanions" class="form-label">Maximale Begleitpersonen</label>
                                    <InputNumber id="maxCompanions" class="form-control" @bind-Value="Model.MaxCompanions" />
                                    <ValidationMessage For="@(() => Model.MaxCompanions)" />
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Section 2: Termine (Dates) -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h4 class="mb-0">Termine (CET)</h4>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="startDate" class="form-label">Startdatum (CET) *</label>
                            <input type="datetime-local" id="startDate" class="form-control" @bind="startDateCet" />
                            <ValidationMessage For="@(() => Model.StartDateUtc)" />
                        </div>

                        <div class="mb-3">
                            <label for="endDate" class="form-label">Enddatum (CET) *</label>
                            <input type="datetime-local" id="endDate" class="form-control" @bind="endDateCet" />
                            <ValidationMessage For="@(() => Model.EndDateUtc)" />
                        </div>

                        @if (Model.EventType == EventType.InPerson)
                        {
                            <div class="mb-3">
                                <label for="registrationDeadline" class="form-label">Anmeldefrist (CET) *</label>
                                <input type="datetime-local" id="registrationDeadline" class="form-control" @bind="registrationDeadlineCet" />
                                <ValidationMessage For="@(() => Model.RegistrationDeadlineUtc)" />
                            </div>
                        }
                    </div>
                </div>

                <!-- Section 3: Kontaktperson (Contact Person) -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h4 class="mb-0">Kontaktperson</h4>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="contactName" class="form-label">Name</label>
                            <InputText id="contactName" class="form-control" @bind-Value="Model.ContactName" />
                            <ValidationMessage For="@(() => Model.ContactName)" />
                        </div>

                        <div class="mb-3">
                            <label for="contactEmail" class="form-label">E-Mail</label>
                            <InputText id="contactEmail" type="email" class="form-control" @bind-Value="Model.ContactEmail" />
                            <ValidationMessage For="@(() => Model.ContactEmail)" />
                        </div>

                        <div class="mb-3">
                            <label for="contactPhone" class="form-label">Telefon</label>
                            <InputText id="contactPhone" class="form-control" @bind-Value="Model.ContactPhone" />
                            <ValidationMessage For="@(() => Model.ContactPhone)" />
                        </div>
                    </div>
                </div>

                <!-- Section 4: Dokumente (Documents) -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h4 class="mb-0">Dokumente</h4>
                    </div>
                    <div class="card-body">
                        @if (Model.DocumentPaths.Any())
                        {
                            <ul class="list-group mb-3">
                                @foreach (var docPath in Model.DocumentPaths.ToList())
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span>@GetFileName(docPath)</span>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="@(() => RemoveDocument(docPath))">
                                            Entfernen
                                        </button>
                                    </li>
                                }
                            </ul>
                        }

                        <div class="mb-3">
                            <label for="fileUpload" class="form-label">Dateien hochladen (PDF, JPG, PNG - max. 10 MB)</label>
                            <InputFile id="fileUpload" OnChange="@HandleFileUpload" multiple accept=".pdf,.jpg,.png,.jpeg" class="form-control" />
                        </div>

                        @if (!string.IsNullOrEmpty(fileUploadError))
                        {
                            <div class="alert alert-warning" role="alert">
                                @fileUploadError
                            </div>
                        }
                    </div>
                </div>

                <!-- Section 5: Agendapunkte (Agenda Items) -->
                @if (Model.EventType == EventType.InPerson)
                {
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Agendapunkte</h4>
                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddAgendaItem">
                            <i class="bi bi-plus-circle"></i> Hinzufügen
                        </button>
                    </div>
                    <div class="card-body">
                        @if (!Model.AgendaItems.Any())
                        {
                            <p class="text-muted">Keine Agendapunkte vorhanden.</p>
                        }
                        else
                        {
                            var sortedItems = Model.AgendaItems.OrderBy(a => a.StartDateTimeUtc).ToList();
                            @for (int i = 0; i < sortedItems.Count; i++)
                            {
                                var item = sortedItems[i];
                                var index = i;
                                <div class="card mb-3">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <strong>Agendapunkt @(index + 1)</strong>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="@(() => RemoveAgendaItem(item))">
                                            Entfernen
                                        </button>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label class="form-label">Titel *</label>
                                            <InputText class="form-control" @bind-Value="item.Title" />
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Beschreibung</label>
                                            <InputTextArea class="form-control" rows="2" @bind-Value="item.Description" />
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Startzeit (CET) *</label>
                                                <input type="datetime-local" class="form-control"
                                                       @bind="agendaItemDatesCet[item].StartCet" />
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Endzeit (CET) *</label>
                                                <input type="datetime-local" class="form-control"
                                                       @bind="agendaItemDatesCet[item].EndCet" />
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Kosten Makler (€)</label>
                                                <InputNumber class="form-control" step="0.01" @bind-Value="item.CostForMakler" />
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Kosten Gäste (€)</label>
                                                <InputNumber class="form-control" step="0.01" @bind-Value="item.CostForGuest" />
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-4 mb-3">
                                                <div class="form-check">
                                                    <InputCheckbox class="form-check-input" id="@($"mandatory-{index}")" @bind-Value="item.IsMandatory" />
                                                    <label class="form-check-label" for="@($"mandatory-{index}")">
                                                        Pflichtteilnahme
                                                    </label>
                                                </div>
                                            </div>

                                            <div class="col-md-4 mb-3">
                                                <div class="form-check">
                                                    <InputCheckbox class="form-check-input" id="@($"makler-{index}")" @bind-Value="item.MaklerCanParticipate" />
                                                    <label class="form-check-label" for="@($"makler-{index}")">
                                                        Makler können teilnehmen
                                                    </label>
                                                </div>
                                            </div>

                                            <div class="col-md-4 mb-3">
                                                <div class="form-check">
                                                    <InputCheckbox class="form-check-input" id="@($"guest-{index}")" @bind-Value="item.GuestsCanParticipate" />
                                                    <label class="form-check-label" for="@($"guest-{index}")">
                                                        Gäste können teilnehmen
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Max. Teilnehmer (optional)</label>
                                            <InputNumber class="form-control" @bind-Value="item.MaxParticipants" />
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
                }

                <!-- Section 6: Zusatzoptionen (Extra Options) -->
                @if (Model.EventType == EventType.InPerson)
                {
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Zusatzoptionen</h4>
                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddExtraOption">
                            <i class="bi bi-plus-circle"></i> Hinzufügen
                        </button>
                    </div>
                    <div class="card-body">
                        @if (!Model.EventOptions.Any())
                        {
                            <p class="text-muted">Keine Zusatzoptionen vorhanden.</p>
                        }
                        else
                        {
                            @for (int i = 0; i < Model.EventOptions.Count; i++)
                            {
                                var option = Model.EventOptions.ElementAt(i);
                                var index = i;
                                <div class="card mb-3">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <strong>Zusatzoption @(index + 1)</strong>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="@(() => RemoveExtraOption(option))">
                                            Entfernen
                                        </button>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label class="form-label">Name *</label>
                                            <InputText class="form-control" @bind-Value="option.Name" />
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Beschreibung</label>
                                            <InputTextArea class="form-control" rows="2" @bind-Value="option.Description" />
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Preis (€)</label>
                                                <InputNumber class="form-control" step="0.01" @bind-Value="option.Price" />
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Max. Anzahl (optional)</label>
                                                <InputNumber class="form-control" @bind-Value="option.MaxQuantity" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
                }

                <!-- Form Buttons -->
                <div class="d-flex justify-content-between mb-4">
                    <a href="/admin/events" class="btn btn-secondary">Abbrechen</a>
                    <button type="submit" class="btn btn-primary">Speichern</button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? EventId { get; set; }

    private Event Model { get; set; } = new Event();
    private bool isEditMode = false;
    private string? errorMessage;
    private string? successMessage;
    private string? fileUploadError;

    // CET date fields for display (bound to form inputs)
    private DateTime startDateCet;
    private DateTime endDateCet;
    private DateTime registrationDeadlineCet;

    // File upload handling
    private const long MaxFileSize = 10 * 1024 * 1024; // 10 MB
    private List<IBrowserFile> queuedFiles = new();

    // Helper class for agenda item date tracking
    private class AgendaItemDates
    {
        public DateTime StartCet { get; set; }
        public DateTime EndCet { get; set; }
    }

    // Agenda item date tracking (CET display values)
    private Dictionary<EventAgendaItem, AgendaItemDates> agendaItemDatesCet = new();

    // Track removed items for deletion
    private List<int> removedAgendaItemIds = new();
    private List<int> removedOptionIds = new();

    private void OnEventTypeChanged()
    {
        if (Model.EventType == EventType.Webinar)
        {
            Model.MaxCapacity = 0;
            Model.MaxCompanions = 0;
            Model.AgendaItems.Clear();
            agendaItemDatesCet.Clear();
            Model.EventOptions.Clear();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (EventId.HasValue)
        {
            // Edit mode: Load existing event
            isEditMode = true;
            var evt = await EventService.GetEventByIdAsync(EventId.Value);

            if (evt == null)
            {
                errorMessage = "Veranstaltung nicht gefunden.";
                return;
            }

            Model = evt;

            // Convert UTC dates to CET for display
            startDateCet = TimeZoneHelper.ConvertUtcToCet(
                DateTime.SpecifyKind(Model.StartDateUtc, DateTimeKind.Utc));
            endDateCet = TimeZoneHelper.ConvertUtcToCet(
                DateTime.SpecifyKind(Model.EndDateUtc, DateTimeKind.Utc));
            registrationDeadlineCet = TimeZoneHelper.ConvertUtcToCet(
                DateTime.SpecifyKind(Model.RegistrationDeadlineUtc, DateTimeKind.Utc));

            // Initialize agenda item CET dates
            foreach (var item in Model.AgendaItems)
            {
                agendaItemDatesCet[item] = new AgendaItemDates
                {
                    StartCet = TimeZoneHelper.ConvertUtcToCet(DateTime.SpecifyKind(item.StartDateTimeUtc, DateTimeKind.Utc)),
                    EndCet = TimeZoneHelper.ConvertUtcToCet(DateTime.SpecifyKind(item.EndDateTimeUtc, DateTimeKind.Utc))
                };
            }
        }
        else
        {
            // Create mode: Initialize with sensible defaults
            var tomorrowUtc = DateTime.UtcNow.Date.AddDays(1);
            Model = new Event
            {
                StartDateUtc = tomorrowUtc.AddHours(10), // 10 AM next day
                EndDateUtc = tomorrowUtc.AddHours(18),    // 6 PM next day
                RegistrationDeadlineUtc = tomorrowUtc.AddDays(-1), // Day before
                MaxCapacity = 50,
                MaxCompanions = 1
            };

            // Convert to CET for display
            startDateCet = TimeZoneHelper.ConvertUtcToCet(
                DateTime.SpecifyKind(Model.StartDateUtc, DateTimeKind.Utc));
            endDateCet = TimeZoneHelper.ConvertUtcToCet(
                DateTime.SpecifyKind(Model.EndDateUtc, DateTimeKind.Utc));
            registrationDeadlineCet = TimeZoneHelper.ConvertUtcToCet(
                DateTime.SpecifyKind(Model.RegistrationDeadlineUtc, DateTimeKind.Utc));
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            // Convert CET dates back to UTC for event
            Model.StartDateUtc = TimeZoneHelper.ConvertCetToUtc(startDateCet);
            Model.EndDateUtc = TimeZoneHelper.ConvertCetToUtc(endDateCet);
            Model.RegistrationDeadlineUtc = TimeZoneHelper.ConvertCetToUtc(registrationDeadlineCet);

            // Convert CET dates back to UTC for all agenda items
            foreach (var item in Model.AgendaItems)
            {
                if (agendaItemDatesCet.ContainsKey(item))
                {
                    var dates = agendaItemDatesCet[item];
                    item.StartDateTimeUtc = TimeZoneHelper.ConvertCetToUtc(dates.StartCet);
                    item.EndDateTimeUtc = TimeZoneHelper.ConvertCetToUtc(dates.EndCet);
                }
            }

            if (isEditMode)
            {
                // Update existing event
                // Note: EF Core change tracking will handle AgendaItems and EventOptions modifications
                await EventService.UpdateEventAsync(Model);
                successMessage = "Veranstaltung erfolgreich aktualisiert.";
            }
            else
            {
                // Create new event with all child collections
                var createdEvent = await EventService.CreateEventAsync(Model);

                // Upload queued files if any
                if (queuedFiles.Any())
                {
                    foreach (var file in queuedFiles)
                    {
                        try
                        {
                            using var stream = file.OpenReadStream(MaxFileSize);
                            var path = await EventService.SaveDocumentAsync(createdEvent.Id, file.Name, stream);
                            createdEvent.DocumentPaths.Add(path);
                        }
                        catch (Exception ex)
                        {
                            fileUploadError = $"Fehler beim Hochladen von {file.Name}: {ex.Message}";
                        }
                    }

                    // Update event with document paths
                    if (createdEvent.DocumentPaths.Any())
                    {
                        await EventService.UpdateEventAsync(createdEvent);
                    }

                    queuedFiles.Clear();
                }

                successMessage = "Veranstaltung erfolgreich erstellt.";
            }

            // Navigate back to list after a short delay
            await Task.Delay(1500);
            NavigationManager.NavigateTo("/admin/events");
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler beim Speichern: {ex.Message}";
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        fileUploadError = null;

        foreach (var file in e.GetMultipleFiles())
        {
            // Validate file size
            if (file.Size > MaxFileSize)
            {
                fileUploadError = $"Datei {file.Name} überschreitet die maximale Größe von 10 MB";
                continue;
            }

            if (isEditMode && Model.Id > 0)
            {
                // Edit mode: Upload immediately
                try
                {
                    using var stream = file.OpenReadStream(MaxFileSize);
                    var path = await EventService.SaveDocumentAsync(Model.Id, file.Name, stream);
                    Model.DocumentPaths.Add(path);
                }
                catch (Exception ex)
                {
                    fileUploadError = $"Fehler beim Hochladen von {file.Name}: {ex.Message}";
                }
            }
            else
            {
                // Create mode: Queue files for upload after event is created
                queuedFiles.Add(file);
            }
        }

        StateHasChanged();
    }

    private async Task RemoveDocument(string docPath)
    {
        try
        {
            await EventService.DeleteDocumentAsync(docPath);
            Model.DocumentPaths.Remove(docPath);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler beim Löschen des Dokuments: {ex.Message}";
        }
    }

    private string GetFileName(string path)
    {
        // Extract filename from path, removing GUID prefix
        var fileName = Path.GetFileName(path);
        var underscoreIndex = fileName.IndexOf('_');
        return underscoreIndex > 0 ? fileName.Substring(underscoreIndex + 1) : fileName;
    }

    private void AddAgendaItem()
    {
        var newItem = new EventAgendaItem
        {
            EventId = Model.Id,
            MaklerCanParticipate = true,
            GuestsCanParticipate = true,
            StartDateTimeUtc = Model.StartDateUtc,
            EndDateTimeUtc = Model.EndDateUtc
        };

        // Add to collection
        if (Model.AgendaItems is List<EventAgendaItem> list)
        {
            list.Add(newItem);
        }
        else
        {
            var newList = Model.AgendaItems.ToList();
            newList.Add(newItem);
            Model.AgendaItems = newList;
        }

        // Initialize CET dates for the new item
        agendaItemDatesCet[newItem] = new AgendaItemDates
        {
            StartCet = TimeZoneHelper.ConvertUtcToCet(DateTime.SpecifyKind(newItem.StartDateTimeUtc, DateTimeKind.Utc)),
            EndCet = TimeZoneHelper.ConvertUtcToCet(DateTime.SpecifyKind(newItem.EndDateTimeUtc, DateTimeKind.Utc))
        };

        StateHasChanged();
    }

    private void RemoveAgendaItem(EventAgendaItem item)
    {
        // Track for deletion if existing item
        if (item.Id > 0)
        {
            removedAgendaItemIds.Add(item.Id);
        }

        // Remove from collection
        if (Model.AgendaItems is List<EventAgendaItem> list)
        {
            list.Remove(item);
        }
        else
        {
            var newList = Model.AgendaItems.ToList();
            newList.Remove(item);
            Model.AgendaItems = newList;
        }

        // Remove from CET tracking
        agendaItemDatesCet.Remove(item);

        StateHasChanged();
    }

    private void AddExtraOption()
    {
        var newOption = new EventOption
        {
            EventId = Model.Id
        };

        if (Model.EventOptions is List<EventOption> list)
        {
            list.Add(newOption);
        }
        else
        {
            var newList = Model.EventOptions.ToList();
            newList.Add(newOption);
            Model.EventOptions = newList;
        }

        StateHasChanged();
    }

    private async Task RemoveExtraOption(EventOption option)
    {
        // If existing option, check if it can be deleted
        if (option.Id > 0)
        {
            var result = await EventService.DeleteEventOptionAsync(option.Id);
            if (!result.Success)
            {
                errorMessage = result.ErrorMessage;
                StateHasChanged();
                return;
            }
        }

        // Remove from collection
        if (Model.EventOptions is List<EventOption> list)
        {
            list.Remove(option);
        }
        else
        {
            var newList = Model.EventOptions.ToList();
            newList.Remove(option);
            Model.EventOptions = newList;
        }

        StateHasChanged();
    }
}
