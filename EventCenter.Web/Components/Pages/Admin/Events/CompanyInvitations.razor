@page "/admin/events/{EventId:int}/companies"
@attribute [Authorize(Policy = "AdminOnly")]
@rendermode InteractiveServer
@inject CompanyInvitationService CompanyInvitationService
@inject EventService EventService
@inject NavigationManager Navigation
@using EventCenter.Web.Domain.Enums
@using EventCenter.Web.Services
@using EventCenter.Web.Infrastructure.Helpers

<PageTitle>Firmeneinladungen</PageTitle>

<div class="container-fluid py-4">
    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Lädt...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Header Section -->
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/admin/events">Veranstaltungen</a></li>
                        <li class="breadcrumb-item"><a href="/admin/events/@EventId">@currentEvent?.Title</a></li>
                        <li class="breadcrumb-item active">Firmeneinladungen</li>
                    </ol>
                </nav>
                <h2>Firmeneinladungen</h2>
                @if (currentEvent != null)
                {
                    <p class="text-muted">@currentEvent.Title</p>
                }
            </div>
            <div class="btn-group">
                <button class="btn btn-primary" @onclick="CreateSingleInvitation">
                    <i class="bi bi-plus-circle"></i> Firma einladen
                </button>
                <button class="btn btn-secondary" @onclick="CreateBatchInvitation">
                    <i class="bi bi-people"></i> Sammeleinladung
                </button>
            </div>
        </div>

        <!-- Alert Messages -->
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }

        @if (invitations.Count == 0)
        {
            <!-- Empty State -->
            <div class="card text-center py-5">
                <div class="card-body">
                    <i class="bi bi-mailbox2 display-1 text-muted"></i>
                    <h4 class="mt-3">Noch keine Firmen eingeladen</h4>
                    <p class="text-muted">Beginnen Sie mit der Einladung von Firmen zu dieser Veranstaltung.</p>
                    <button class="btn btn-primary btn-lg mt-3" @onclick="CreateSingleInvitation">
                        <i class="bi bi-plus-circle"></i> Firma einladen
                    </button>
                </div>
            </div>
        }
        else
        {
            <!-- Status Summary Row -->
            <div class="mb-3">
                <span class="badge bg-secondary me-2">@draftCount Entwürfe</span>
                <span class="badge bg-info me-2">@sentCount Versendet</span>
                <span class="badge bg-success me-2">@bookedCount Gebucht</span>
                <span class="badge bg-danger">@cancelledCount Storniert</span>
            </div>

            <!-- Sortable Table -->
            <div class="card">
                <div class="card-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th style="cursor: pointer;" @onclick="() => ToggleSort(nameof(EventCompany.CompanyName))">
                                    Firma
                                    @if (sortColumn == nameof(EventCompany.CompanyName))
                                    {
                                        <i class="bi bi-arrow-@(sortAscending ? "up" : "down")"></i>
                                    }
                                </th>
                                <th>Kontakt</th>
                                <th style="cursor: pointer;" @onclick="() => ToggleSort(nameof(EventCompany.Status))">
                                    Status
                                    @if (sortColumn == nameof(EventCompany.Status))
                                    {
                                        <i class="bi bi-arrow-@(sortAscending ? "up" : "down")"></i>
                                    }
                                </th>
                                <th style="cursor: pointer;" @onclick="() => ToggleSort(nameof(EventCompany.InvitationSentUtc))">
                                    Gesendet am
                                    @if (sortColumn == nameof(EventCompany.InvitationSentUtc))
                                    {
                                        <i class="bi bi-arrow-@(sortAscending ? "up" : "down")"></i>
                                    }
                                </th>
                                <th>Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var invitation in SortedInvitations)
                            {
                                <tr>
                                    <td>@invitation.CompanyName</td>
                                    <td>
                                        <div>@invitation.ContactEmail</div>
                                        @if (!string.IsNullOrEmpty(invitation.ContactPhone))
                                        {
                                            <small class="text-muted">@invitation.ContactPhone</small>
                                        }
                                    </td>
                                    <td>
                                        @switch (invitation.Status)
                                        {
                                            case InvitationStatus.Draft:
                                                <span class="badge bg-secondary">Entwurf</span>
                                                break;
                                            case InvitationStatus.Sent:
                                                <span class="badge bg-info">Versendet</span>
                                                break;
                                            case InvitationStatus.Booked:
                                                <span class="badge bg-success">Gebucht</span>
                                                break;
                                            case InvitationStatus.Cancelled:
                                                <span class="badge bg-danger">Storniert</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (invitation.InvitationSentUtc.HasValue)
                                        {
                                            @TimeZoneHelper.FormatDateTimeCet(invitation.InvitationSentUtc.Value)
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            @if (invitation.Status == InvitationStatus.Draft)
                                            {
                                                <button class="btn btn-secondary" title="Bearbeiten" @onclick="() => EditInvitation(invitation.Id)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-primary" title="Senden" @onclick="() => SendInvitation(invitation.Id)">
                                                    <i class="bi bi-envelope"></i>
                                                </button>
                                                <button class="btn btn-danger" title="Löschen" @onclick="() => ShowDeleteConfirmation(invitation)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                            else if (invitation.Status == InvitationStatus.Sent)
                                            {
                                                <button class="btn btn-secondary" title="Bearbeiten" @onclick="() => EditInvitation(invitation.Id)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-warning" title="Erneut senden" @onclick="() => ResendInvitation(invitation.Id)">
                                                    <i class="bi bi-envelope-arrow-up"></i>
                                                </button>
                                                <button class="btn btn-danger" title="Löschen" @onclick="() => ShowDeleteConfirmation(invitation)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                            else if (invitation.Status == InvitationStatus.Booked)
                                            {
                                                <button class="btn btn-secondary" title="Bearbeiten" @onclick="() => EditInvitation(invitation.Id)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-info" title="Buchung ansehen" @onclick="() => ViewBooking(invitation.Id)">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                            }
                                            else if (invitation.Status == InvitationStatus.Cancelled)
                                            {
                                                <button class="btn btn-secondary" title="Bearbeiten" @onclick="() => EditInvitation(invitation.Id)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-primary" title="Erneut einladen" @onclick="() => ReinviteCompany(invitation.Id)">
                                                    <i class="bi bi-arrow-clockwise"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

<!-- Delete Confirmation Modal -->
@if (invitationToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Einladung löschen</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Möchten Sie die Einladung für <strong>@invitationToDelete.CompanyName</strong> (Status: <strong>@GetStatusText(invitationToDelete.Status)</strong>) wirklich löschen?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Abbrechen</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Löschen</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int EventId { get; set; }

    private Event? currentEvent;
    private List<EventCompany> invitations = new();
    private bool loading = true;
    private string? successMessage;
    private string? errorMessage;

    // Status counts
    private int draftCount => invitations.Count(i => i.Status == InvitationStatus.Draft);
    private int sentCount => invitations.Count(i => i.Status == InvitationStatus.Sent);
    private int bookedCount => invitations.Count(i => i.Status == InvitationStatus.Booked);
    private int cancelledCount => invitations.Count(i => i.Status == InvitationStatus.Cancelled);

    // Sorting
    private string sortColumn = nameof(EventCompany.CompanyName);
    private bool sortAscending = true;

    // Delete confirmation
    private EventCompany? invitationToDelete;

    private IEnumerable<EventCompany> SortedInvitations
    {
        get
        {
            IEnumerable<EventCompany> sorted = invitations;

            if (sortColumn == nameof(EventCompany.CompanyName))
            {
                sorted = sortAscending
                    ? sorted.OrderBy(i => i.CompanyName)
                    : sorted.OrderByDescending(i => i.CompanyName);
            }
            else if (sortColumn == nameof(EventCompany.Status))
            {
                sorted = sortAscending
                    ? sorted.OrderBy(i => i.Status)
                    : sorted.OrderByDescending(i => i.Status);
            }
            else if (sortColumn == nameof(EventCompany.InvitationSentUtc))
            {
                sorted = sortAscending
                    ? sorted.OrderBy(i => i.InvitationSentUtc ?? DateTime.MinValue)
                    : sorted.OrderByDescending(i => i.InvitationSentUtc ?? DateTime.MinValue);
            }

            return sorted;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            currentEvent = await EventService.GetEventByIdAsync(EventId);
            invitations = await CompanyInvitationService.GetInvitationsForEventAsync(EventId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler beim Laden der Daten: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ToggleSort(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private void CreateSingleInvitation()
    {
        Navigation.NavigateTo($"/admin/events/{EventId}/companies/create");
    }

    private void CreateBatchInvitation()
    {
        Navigation.NavigateTo($"/admin/events/{EventId}/companies/create-batch");
    }

    private void EditInvitation(int invitationId)
    {
        Navigation.NavigateTo($"/admin/events/{EventId}/companies/edit/{invitationId}");
    }

    private async Task SendInvitation(int invitationId)
    {
        try
        {
            var (success, error) = await CompanyInvitationService.SendInvitationAsync(invitationId);
            if (success)
            {
                successMessage = "Einladung erfolgreich versendet.";
                await RefreshInvitations();
                AutoDismissSuccess();
            }
            else
            {
                errorMessage = error ?? "Fehler beim Versenden der Einladung.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler: {ex.Message}";
        }
    }

    private async Task ResendInvitation(int invitationId)
    {
        try
        {
            var (success, error) = await CompanyInvitationService.ResendInvitationAsync(invitationId);
            if (success)
            {
                successMessage = "Einladung erfolgreich erneut versendet.";
                await RefreshInvitations();
                AutoDismissSuccess();
            }
            else
            {
                errorMessage = error ?? "Fehler beim erneuten Versenden der Einladung.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler: {ex.Message}";
        }
    }

    private async Task ReinviteCompany(int invitationId)
    {
        try
        {
            var (success, error) = await CompanyInvitationService.SendInvitationAsync(invitationId);
            if (success)
            {
                successMessage = "Firma erfolgreich erneut eingeladen.";
                await RefreshInvitations();
                AutoDismissSuccess();
            }
            else
            {
                errorMessage = error ?? "Fehler beim erneuten Einladen.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler: {ex.Message}";
        }
    }

    private void ViewBooking(int invitationId)
    {
        // Placeholder for Phase 5
        errorMessage = "Buchungsdetails werden in Phase 5 implementiert.";
    }

    private void ShowDeleteConfirmation(EventCompany invitation)
    {
        invitationToDelete = invitation;
    }

    private void CancelDelete()
    {
        invitationToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (invitationToDelete == null) return;

        try
        {
            var (success, error) = await CompanyInvitationService.DeleteInvitationAsync(invitationToDelete.Id);
            if (success)
            {
                successMessage = $"Einladung für {invitationToDelete.CompanyName} erfolgreich gelöscht.";
                await RefreshInvitations();
                AutoDismissSuccess();
            }
            else
            {
                errorMessage = error ?? "Fehler beim Löschen der Einladung.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler: {ex.Message}";
        }
        finally
        {
            invitationToDelete = null;
        }
    }

    private async Task RefreshInvitations()
    {
        invitations = await CompanyInvitationService.GetInvitationsForEventAsync(EventId);
        StateHasChanged();
    }

    private string GetStatusText(InvitationStatus status)
    {
        return status switch
        {
            InvitationStatus.Draft => "Entwurf",
            InvitationStatus.Sent => "Versendet",
            InvitationStatus.Booked => "Gebucht",
            InvitationStatus.Cancelled => "Storniert",
            _ => status.ToString()
        };
    }

    private async void AutoDismissSuccess()
    {
        await Task.Delay(5000);
        successMessage = null;
        StateHasChanged();
    }
}
