@page "/portal/events/{EventId:int}/register"
@using EventCenter.Web.Services
@using EventCenter.Web.Domain.Entities
@using EventCenter.Web.Domain.Enums
@using EventCenter.Web.Domain.Extensions
@using EventCenter.Web.Infrastructure.Helpers
@using EventCenter.Web.Models
@using EventCenter.Web.Validators
@using EventCenter.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Blazored.FluentValidation
@attribute [Authorize(Roles = "Makler")]
@rendermode InteractiveServer
@inject EventService EventService
@inject RegistrationService RegistrationService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Anmeldung - @(evt?.Title ?? "Veranstaltung") - Veranstaltungscenter</PageTitle>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Lädt...</span>
        </div>
        <p class="mt-2 text-muted">Veranstaltung wird geladen...</p>
    </div>
}
else if (evt == null)
{
    <div class="alert alert-danger">
        <h4 class="alert-heading">Veranstaltung nicht gefunden</h4>
        <p>Die angeforderte Veranstaltung konnte nicht gefunden werden.</p>
        <a href="/portal/events" class="btn btn-primary">Zurück zur Übersicht</a>
    </div>
}
else
{
    <div class="container py-4">
        <!-- Header -->
        <div class="mb-4">
            <h2>Anmeldung: @evt.Title</h2>
            <p class="text-muted">
                <i class="bi bi-calendar-event"></i> @TimeZoneHelper.FormatDateTimeCet(DateTime.SpecifyKind(evt.StartDateUtc, DateTimeKind.Utc), "dd.MM.yyyy HH:mm")
                -
                @TimeZoneHelper.FormatDateTimeCet(DateTime.SpecifyKind(evt.EndDateUtc, DateTimeKind.Utc), "HH:mm")
                |
                <i class="bi bi-geo-alt"></i> @evt.Location
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle"></i> @errorMessage
                <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
            </div>
        }

        <EditForm Model="@model" OnValidSubmit="@(() => { })">
            <FluentValidationValidator />

            <!-- Personal Info Section -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Persönliche Daten</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Vorname <span class="text-danger">*</span></label>
                            <InputText @bind-Value="model.FirstName" class="form-control" placeholder="Vorname" />
                            <ValidationMessage For="@(() => model.FirstName)" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nachname <span class="text-danger">*</span></label>
                            <InputText @bind-Value="model.LastName" class="form-control" placeholder="Nachname" />
                            <ValidationMessage For="@(() => model.LastName)" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">E-Mail <span class="text-danger">*</span></label>
                        <InputText @bind-Value="model.Email" class="form-control" placeholder="email@example.com" readonly />
                        <small class="form-text text-muted">Ihre E-Mail-Adresse aus dem Benutzerkonto.</small>
                        <ValidationMessage For="@(() => model.Email)" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Telefon (optional)</label>
                            <InputText @bind-Value="model.Phone" class="form-control" placeholder="+49 123 456789" />
                            <ValidationMessage For="@(() => model.Phone)" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Firma (optional)</label>
                            <InputText @bind-Value="model.Company" class="form-control" placeholder="Firmenname" />
                            <ValidationMessage For="@(() => model.Company)" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Agenda Item Selection Section -->
            @{
                var maklerAgendaItems = evt.AgendaItems
                    .Where(ai => ai.MaklerCanParticipate)
                    .OrderBy(ai => ai.StartDateTimeUtc)
                    .ToList();
            }

            @if (maklerAgendaItems.Any())
            {
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Agendapunkte auswählen</h4>
                    </div>
                    <div class="card-body">
                        @if (!model.SelectedAgendaItemIds.Any() && !maklerAgendaItems.Any(ai => ai.IsMandatory))
                        {
                            <div class="alert alert-warning mb-3">
                                <i class="bi bi-exclamation-triangle"></i> Bitte wählen Sie mindestens einen Agendapunkt aus.
                            </div>
                        }

                        @foreach (var item in maklerAgendaItems)
                        {
                            var isSelected = model.SelectedAgendaItemIds.Contains(item.Id);
                            var isMandatory = item.IsMandatory;

                            <div class="form-check card p-3 mb-2 @(isSelected ? "border-primary" : "")">
                                <input type="checkbox"
                                       class="form-check-input"
                                       id="agenda-@item.Id"
                                       checked="@isSelected"
                                       disabled="@isMandatory"
                                       @onchange="@(() => ToggleAgendaItem(item.Id, isMandatory))" />
                                <label class="form-check-label w-100" for="agenda-@item.Id" style="cursor: pointer;">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong>@item.Title</strong>
                                            @if (isMandatory)
                                            {
                                                <span class="badge bg-warning text-dark ms-2">Pflicht</span>
                                            }
                                            <br/>
                                            <small class="text-muted">
                                                <i class="bi bi-clock"></i>
                                                @TimeZoneHelper.FormatDateTimeCet(DateTime.SpecifyKind(item.StartDateTimeUtc, DateTimeKind.Utc), "dd.MM.yyyy HH:mm")
                                                - @TimeZoneHelper.FormatDateTimeCet(DateTime.SpecifyKind(item.EndDateTimeUtc, DateTimeKind.Utc), "HH:mm")
                                            </small>
                                            @if (!string.IsNullOrWhiteSpace(item.Description))
                                            {
                                                <br/>
                                                <small class="text-muted">@item.Description</small>
                                            }
                                        </div>
                                        <div class="text-end">
                                            @if (item.CostForMakler > 0)
                                            {
                                                <span class="badge bg-primary">@item.CostForMakler.ToString("N2") EUR</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Kostenfrei</span>
                                            }
                                        </div>
                                    </div>
                                </label>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Cost Summary Section -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Kostenübersicht</h4>
                </div>
                <div class="card-body">
                    @{
                        var selectedItems = evt.AgendaItems
                            .Where(ai => model.SelectedAgendaItemIds.Contains(ai.Id))
                            .ToList();
                        var totalCost = selectedItems.Sum(item => item.CostForMakler);
                    }

                    @if (selectedItems.Any())
                    {
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Agendapunkt</th>
                                    <th class="text-end">Kosten</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in selectedItems)
                                {
                                    <tr>
                                        <td>@item.Title</td>
                                        <td class="text-end">
                                            @if (item.CostForMakler > 0)
                                            {
                                                @item.CostForMakler.ToString("N2")<text> EUR</text>
                                            }
                                            else
                                            {
                                                <span class="text-success">Kostenfrei</span>
                                            }
                                        </td>
                                    </tr>
                                }
                                <tr class="fw-bold border-top">
                                    <td>Gesamt</td>
                                    <td class="text-end">@totalCost.ToString("N2") EUR</td>
                                </tr>
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Keine Agendapunkte ausgewählt.</p>
                    }
                </div>
            </div>

            <!-- Submit Buttons -->
            <div class="d-flex justify-content-between">
                <a href="/portal/events/@EventId" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Abbrechen
                </a>
                <button type="button"
                        class="btn btn-primary btn-lg"
                        @onclick="ShowConfirmation"
                        disabled="@(isSubmitting || !model.SelectedAgendaItemIds.Any() || string.IsNullOrWhiteSpace(model.FirstName) || string.IsNullOrWhiteSpace(model.LastName) || string.IsNullOrWhiteSpace(model.Email))">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Wird verarbeitet...</span>
                    }
                    else
                    {
                        <i class="bi bi-check-circle"></i>
                        <span>Anmeldung abschließen</span>
                    }
                </button>
            </div>
        </EditForm>

        <!-- Confirmation Dialog -->
        <ConfirmDialog Show="@showConfirmDialog"
                       Title="Anmeldung bestätigen"
                       Message="@confirmationMessage"
                       ConfirmText="Anmeldung bestätigen"
                       ConfirmButtonCss="btn-primary"
                       OnConfirm="SubmitRegistration"
                       OnCancel="@(() => showConfirmDialog = false)" />
    </div>
}

@code {
    [Parameter]
    public int EventId { get; set; }

    private Event? evt;
    private RegistrationFormModel model = new();
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool showConfirmDialog = false;
    private string? errorMessage = null;
    private string confirmationMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Get user email from authentication state
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userEmail = user.FindFirst("preferred_username")?.Value
                ?? user.FindFirst("email")?.Value
                ?? string.Empty;

            // Load event
            evt = await EventService.GetEventByIdAsync(EventId);

            // Validate event is available for registration
            if (evt == null || !evt.IsPublished)
            {
                NavigationManager.NavigateTo("/portal/events");
                return;
            }

            // Redirect webinar events to detail page (no internal registration form)
            if (evt.EventType == EventType.Webinar)
            {
                NavigationManager.NavigateTo($"/portal/events/{EventId}");
                return;
            }

            var eventState = evt.GetCurrentState();
            if (eventState != EventState.Public)
            {
                NavigationManager.NavigateTo($"/portal/events/{EventId}");
                return;
            }

            var isFull = evt.GetCurrentRegistrationCount() >= evt.MaxCapacity;
            if (isFull)
            {
                NavigationManager.NavigateTo($"/portal/events/{EventId}");
                return;
            }

            // Check if user is already registered
            var isAlreadyRegistered = evt.Registrations?.Any(r =>
                r.Email.Equals(userEmail, StringComparison.OrdinalIgnoreCase) &&
                !r.IsCancelled) ?? false;

            if (isAlreadyRegistered)
            {
                NavigationManager.NavigateTo($"/portal/events/{EventId}");
                return;
            }

            // Pre-fill form
            model.EventId = EventId;
            model.Email = userEmail;

            // Pre-select mandatory agenda items
            var mandatoryItemIds = evt.AgendaItems
                .Where(ai => ai.MaklerCanParticipate && ai.IsMandatory)
                .Select(ai => ai.Id)
                .ToList();

            model.SelectedAgendaItemIds = mandatoryItemIds;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleAgendaItem(int itemId, bool isMandatory)
    {
        if (isMandatory)
        {
            // Cannot toggle mandatory items
            return;
        }

        if (model.SelectedAgendaItemIds.Contains(itemId))
        {
            model.SelectedAgendaItemIds.Remove(itemId);
        }
        else
        {
            model.SelectedAgendaItemIds.Add(itemId);
        }

        // Force UI update
        StateHasChanged();
    }

    private void ShowConfirmation()
    {
        if (evt == null)
            return;

        // Build confirmation message
        var selectedItems = evt.AgendaItems
            .Where(ai => model.SelectedAgendaItemIds.Contains(ai.Id))
            .ToList();

        var totalCost = selectedItems.Sum(item => item.CostForMakler);

        var messageBuilder = new System.Text.StringBuilder();
        messageBuilder.AppendLine("Sie möchten sich für folgende Agendapunkte anmelden:");
        messageBuilder.AppendLine();

        foreach (var item in selectedItems)
        {
            var cost = item.CostForMakler > 0 ? $"{item.CostForMakler:N2} EUR" : "Kostenfrei";
            messageBuilder.AppendLine($"• {item.Title}: {cost}");
        }

        messageBuilder.AppendLine();
        messageBuilder.AppendLine($"Gesamtkosten: {totalCost:N2} EUR");

        confirmationMessage = messageBuilder.ToString();
        showConfirmDialog = true;
    }

    private async Task SubmitRegistration()
    {
        isSubmitting = true;
        showConfirmDialog = false;
        errorMessage = null;

        try
        {
            var (success, registrationId, error) = await RegistrationService.RegisterMaklerAsync(
                EventId,
                model.Email,
                model.FirstName,
                model.LastName,
                model.Phone,
                model.Company,
                model.SelectedAgendaItemIds);

            if (success && registrationId.HasValue)
            {
                NavigationManager.NavigateTo($"/portal/registrations/{registrationId.Value}/confirmation");
            }
            else
            {
                errorMessage = error ?? "Ein Fehler ist aufgetreten.";
                isSubmitting = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Ein unerwarteter Fehler ist aufgetreten. Bitte versuchen Sie es später erneut.";
            isSubmitting = false;
        }
    }
}
