@page "/portal"
@attribute [Authorize(Roles = "Makler")]
@layout MainLayout

<PageTitle>Portal - Veranstaltungscenter</PageTitle>

<h1>Makler Portal</h1>

<AuthorizeView Roles="Makler">
    <Authorized>
        <p>Willkommen im Portal, @context.User.Identity?.Name!</p>

        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Veranstaltungen</h5>
                        <p class="card-text">Verfügbare Veranstaltungen ansehen und anmelden</p>
                        <a href="/portal/events" class="btn btn-primary">Zur Übersicht</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Meine Anmeldungen</h5>
                        <p class="card-text">Ihre Anmeldungen und Gäste verwalten</p>
                        <a href="/portal/registrations" class="btn btn-primary">Zur Verwaltung</a>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <p>Zugriff verweigert. Sie benötigen Makler-Rechte.</p>
    </NotAuthorized>
</AuthorizeView>
