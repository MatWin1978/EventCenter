@page "/portal/registrations"
@attribute [Authorize(Roles = "Makler")]
@layout MainLayout
@using EventCenter.Web.Services
@using EventCenter.Web.Domain.Entities
@using EventCenter.Web.Domain.Enums
@using EventCenter.Web.Infrastructure.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@inject RegistrationService RegistrationService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Meine Anmeldungen - Veranstaltungscenter</PageTitle>

<h2>Meine Anmeldungen</h2>

@if (isLoading)
{
    <div class="text-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Lade...</span>
        </div>
        <p class="mt-2">Lade...</p>
    </div>
}
else if (!registrations.Any())
{
    <div class="alert alert-info">
        <p>Sie haben sich noch für keine Veranstaltung angemeldet.</p>
        <a href="/portal/events" class="btn btn-primary btn-sm">Veranstaltungen ansehen</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var reg in registrations)
        {
            <div class="col">
                <div class="card h-100 @(reg.IsCancelled ? "opacity-50" : "")">
                    <div class="card-body d-flex flex-column">

                        <!-- Title + cancelled badge -->
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h5 class="card-title mb-0">@reg.Event.Title</h5>
                            @if (reg.IsCancelled)
                            {
                                <span class="badge bg-secondary ms-2">Storniert</span>
                            }
                        </div>

                        <!-- Event date + location/webinar -->
                        <div class="text-muted small mb-2">
                            <span class="me-3">
                                <i class="bi bi-calendar"></i> @TimeZoneHelper.FormatDateTimeCet(reg.Event.StartDateUtc, "dd.MM.yyyy")
                            </span>
                            @if (reg.Event.EventType == EventType.Webinar)
                            {
                                <span class="badge bg-info"><i class="bi bi-camera-video"></i> Webinar</span>
                            }
                            else
                            {
                                <span><i class="bi bi-geo-alt"></i> @reg.Event.Location</span>
                            }
                        </div>

                        <!-- Registration date -->
                        <p class="text-muted small mb-2">
                            <i class="bi bi-clock"></i> Angemeldet am @TimeZoneHelper.FormatDateTimeCet(reg.RegistrationDateUtc, "dd.MM.yyyy")
                        </p>

                        <!-- Booked agenda items (broker) -->
                        @if (reg.RegistrationAgendaItems.Any())
                        {
                            <div class="mb-2">
                                <strong class="small">Agendapunkte:</strong>
                                <ul class="list-unstyled mb-0 small">
                                    @foreach (var rai in reg.RegistrationAgendaItems)
                                    {
                                        <li>
                                            <i class="bi bi-check2"></i> @rai.AgendaItem.Title
                                            @if (rai.AgendaItem.CostForMakler > 0)
                                            {
                                                <span class="text-muted"> (@rai.AgendaItem.CostForMakler.ToString("F2") EUR)</span>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        }

                        <!-- Extra options -->
                        @if (reg.SelectedOptions.Any())
                        {
                            <div class="mb-2">
                                <strong class="small">Zusatzoptionen:</strong>
                                <ul class="list-unstyled mb-0 small">
                                    @foreach (var opt in reg.SelectedOptions)
                                    {
                                        <li>
                                            <i class="bi bi-plus-circle"></i> @opt.Name
                                            @if (opt.Price > 0)
                                            {
                                                <span class="text-muted"> (@opt.Price.ToString("F2") EUR)</span>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        }

                        <!-- Guests inline (locked decision: inline under broker card, not separate) -->
                        @if (reg.GuestRegistrations.Any())
                        {
                            <div class="mb-2">
                                <strong class="small">Begleitpersonen:</strong>
                                <ul class="list-unstyled mb-0 small">
                                    @foreach (var guest in reg.GuestRegistrations)
                                    {
                                        <li class="@(guest.IsCancelled ? "text-muted" : "")">
                                            <i class="bi bi-person"></i>
                                            @guest.FirstName @guest.LastName
                                            @if (guest.IsCancelled)
                                            {
                                                <span class="badge bg-secondary ms-1" style="font-size:0.65em;">Storniert</span>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        }

                        <!-- Total cost -->
                        <div class="mt-auto pt-2">
                            <strong class="small">Gesamt: @GetTotalCost(reg).ToString("F2") EUR</strong>
                        </div>

                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="/portal/events/@reg.EventId" class="btn btn-outline-primary btn-sm w-100">
                            Zur Veranstaltung
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Registration> registrations = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userEmail = authState.User.FindFirst("preferred_username")?.Value
                        ?? authState.User.Identity?.Name ?? string.Empty;

        registrations = await RegistrationService.GetBrokerRegistrationsAsync(userEmail);
        isLoading = false;
    }

    private decimal GetTotalCost(Registration reg)
    {
        var agendaCost = reg.RegistrationAgendaItems.Sum(rai => rai.AgendaItem.CostForMakler);
        var optionsCost = reg.SelectedOptions.Sum(o => o.Price);
        return agendaCost + optionsCost;
    }
}
