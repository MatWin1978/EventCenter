{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=EventCenterDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Keycloak": {
    "Authority": "https://keycloak.example.com/realms/eventcenter",
    "ClientId": "eventcenter-app",
    "ClientSecret": "PLACEHOLDER_TO_BE_REPLACED_BY_USER",
    "RequireHttpsMetadata": true
  },
  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "SenderName": "Veranstaltungscenter",
    "SenderEmail": "noreply@example.com"
  },
  "CompanyBooking": {
    "InvitationExpirationHours": 72,
    "AdminNotificationEmail": "admin@example.com"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
