# Azure-Konfiguration
RESOURCE_GROUP=eventcenter-rg
LOCATION=westeurope
STORAGE_ACCOUNT=eventcenterstorage   # muss global eindeutig sein, nur Kleinbuchstaben/Zahlen

# DNS-Label → App läuft unter http://${DNS_LABEL}.westeurope.azurecontainer.io
DNS_LABEL=eventcenter-app            # muss global eindeutig sein

# Passwörter / Secrets
KC_ADMIN_PASSWORD=ChangeMe123!
KC_CLIENT_SECRET=eventcenter-dev-secret
MSSQL_SA_PASSWORD=EventCenter@2024

# Wird von setup.sh automatisch befüllt — nicht manuell eintragen
STORAGE_KEY=
